<mvc:View controllerName="zhr.flexiblecolumnlayoutlist.controller.List"
    displayBlock="true"
    width="100%"  
    height="100%"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core">
	<f:DynamicPage id="dynamicPageId"
				   toggleHeaderOnTitleClick="false">
		<!-- DynamicPage Title -->
		<f:title>
			<f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
				<f:heading>
					<Title id="_IDGenTitle" text="Apontamentos"/>
				</f:heading>
			</f:DynamicPageTitle>
		</f:title>


        <!-- Header com seleção de período -->
        <f:header>
            <f:DynamicPageHeader id="dynamicPageHeader">
                <f:content>

                    <HBox
                        id="boxFiltrosPeriodo"
                        alignItems="Center"
                        class="sapUiSmallMargin">

						<VBox id="_IDGenVBox13" class="sapUiSmallMarginEnd">
							<Label id="_IDGenLabel13" text="Período" labelFor="cmbPeriodos"/>
							<Select
								id="cmbPeriodos"
								width="300px"
								change=".onComboBoxPeriodosChange"
								items="{mdlPeriodos>/}">
								<core:Item id="_IDGenItem1"
									key="{mdlPeriodos>Periodo}"
									text="{mdlPeriodos>PeriodoTexto}" />
							</Select>
						</VBox>

						<VBox id="_IDGenVBox14" class="sapUiSmallMarginEnd" visible="{mdlAppConfig>/filters/visibleEmpregado}">
							<Label id="_IDGenLabel14" text="Empregado" labelFor="inputEmpregado"/>
							<Input
								id="inputEmpregado"
								width="10rem"
								maxLength="10"
								showValueHelp="true"
								valueHelpRequest=".onValueHelpRequestEmpregado"
								submit=".onPesquisar"/>
						</VBox>

						<VBox id="_IDGenVBox15" class="sapUiSmallMarginEnd">
							<Label id="_IDGenLabel15" text="Tipo de Ocorrência" labelFor="inputTipoOcorrencia"/>
							<Input
								id="inputTipoOcorrencia"
								width="10rem"
								showValueHelp="true"
								valueHelpRequest=".onValueHelpRequestTipoOcorrencia"
								submit=".onPesquisar"/>
						</VBox>

						<VBox id="_IDGenVBox16" class="sapUiSmallMarginEnd">
							<Label id="_IDGenLabel16" text="Status" labelFor="inputStatus"/>
							<Input
								id="inputStatus"
								width="10rem"
								showValueHelp="true"
								valueHelpRequest=".onValueHelpRequestStatus"
								submit=".onPesquisar"/>
						</VBox>

						<VBox id="_IDGenVBox17" class="sapUiSmallMarginEnd" visible="{mdlAppConfig>/filters/visibleEmpregado}">
							<Label id="_IDGenLabel17" text="Gerência" labelFor="inputGerencia"/>
							<Input
								id="inputGerencia"
								width="10rem"
								showValueHelp="true"
								valueHelpRequest=".onValueHelpRequestGerencia"
								submit=".onPesquisar"/>
						</VBox>

						<VBox id="_IDGenVBox18" class="sapUiSmallMarginEnd">
							<Label id="_IDGenLabel18" text=" "/>
							<Button id="_IDGenButton10"
								text="Pesquisar"
								type="Emphasized"
								press=".onPesquisar"/>
						</VBox>

						<VBox id="_IDGenVBox19" class="sapUiSmallMarginEnd">
							<Label id="_IDGenLabel19" text=" "/>
							<Button id="_IDGenButton11"
								text="Limpar Filtros"
								type="Default"
								press=".onLimparFiltros"/>
						</VBox>

                    </HBox>

                </f:content>
            </f:DynamicPageHeader>
        </f:header>

		<!-- DynamicPage Content -->
		<f:content>


			<List
				id="listOcorrencias"
				mode="MultiSelect"
				growing="true"
				growingThreshold="10"
				busyIndicatorDelay="200"
				enableBusyIndicator="true"
				noDataText="Nenhuma ocorrência disponível"
				items="{
					path: 'mdlOcorrenciasFiltradas>/',
					sorter: {
						path: 'UnidadeOrganizacional',
						descending: false,
						group: '.listGroupFunction'
					}
				}">

				<CustomListItem
					id="itemOcorrencia"
					type="Active"
					press=".onListItemPress">

					<VBox id="_IDGenVBox4"
						class="sapUiSmallMarginTop sapUiSmallMarginBottom sapUiSmallMarginBeginEnd">

						<!-- Linha 1: identificação principal -->
						<HBox id="_IDGenHBox"
							alignItems="Center"
							justifyContent="SpaceBetween">

							<VBox id="_IDGenVBox5">
								<ObjectIdentifier id="_IDGenObjectIdentifier"
									title="{mdlOcorrenciasFiltradas>Empregado}"
									text="{mdlOcorrenciasFiltradas>NomeEmpregado}" />

								<Text id="_IDGenText"
									text="{mdlOcorrenciasFiltradas>UnidadeOrganizacional} - {mdlOcorrenciasFiltradas>UnidOrgDescricao}" />
							</VBox>

							<ObjectStatus id="_IDGenObjectStatus"
								text="{
									path: 'mdlOcorrenciasFiltradas>Status',
									formatter: '.formatter.statusText'
								}"
								icon="{
									path: 'mdlOcorrenciasFiltradas>Status',
									formatter: '.formatter.statusIcon'
								}"
								state="{
									path: 'mdlOcorrenciasFiltradas>Status',
									formatter: '.formatter.statusState'
								}" />
							<VBox id="_IDGenVBox6" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel6" text="Data" />
								<Text id="_IDGenText1"
									text="{
										path: 'mdlOcorrenciasFiltradas>Data',
										formatter: '.formatter.formatDateBR'
									}" />
							</VBox>

							<VBox id="_IDGenVBox7" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel7" text="Início" />
								<Input id="_IDGenInput"
									width="6rem"
									value="{
										path: 'mdlOcorrenciasFiltradas>HoraInicio',
										formatter: '.formatter.formatTimeFromMs'
									}"
									editable="{mdlOcorrenciasFiltradas>editModeHoraInicio}" />
							</VBox>

							<VBox id="_IDGenVBox8" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel8" text="Fim" />
								<Input id="_IDGenInput1"
									width="6rem"
									value="{
										path: 'mdlOcorrenciasFiltradas>HoraFim',
										formatter: '.formatter.formatTimeFromMs'
									}"
									editable="{mdlOcorrenciasFiltradas>editModeHoraFim}" />
							</VBox>

							<VBox id="_IDGenVBox9" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel9" text="Diferença" />
								<Text id="_IDGenText2"
									text="{mdlOcorrenciasFiltradas>Diferenca}"
									textAlign="Right" />
							</VBox>
						</HBox>

						<!-- Linha 2: data e horários -->
						<HBox id="_IDGenHBox1"
							class="sapUiSmallMarginTop"
							alignItems="Center"
							wrap="Wrap">

							<!-- <VBox id="_IDGenVBox6" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel6" text="Data" />
								<Text id="_IDGenText1"
									text="{
										path: 'mdlOcorrenciasFiltradas>Data',
										formatter: '.formatter.formatDateBR'
									}" />
							</VBox>

							<VBox id="_IDGenVBox7" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel7" text="Início" />
								<Input id="_IDGenInput"
									width="6rem"
									value="{
										path: 'mdlOcorrenciasFiltradas>HoraInicio',
										formatter: '.formatter.formatTimeFromMs'
									}"
									editable="{mdlOcorrenciasFiltradas>editModeHoraInicio}" />
							</VBox>

							<VBox id="_IDGenVBox8" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel8" text="Fim" />
								<Input id="_IDGenInput1"
									width="6rem"
									value="{
										path: 'mdlOcorrenciasFiltradas>HoraFim',
										formatter: '.formatter.formatTimeFromMs'
									}"
									editable="{mdlOcorrenciasFiltradas>editModeHoraFim}" />
							</VBox>

							<VBox id="_IDGenVBox9" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel9" text="Diferença" />
								<Text id="_IDGenText2"
									text="{mdlOcorrenciasFiltradas>Diferenca}"
									textAlign="Right" />
							</VBox> -->

						</HBox>

						<!-- Linha 3: ocorrência e justificativa -->
						<HBox id="_IDGenHBox2"
							class="sapUiSmallMarginTop"
							alignItems="Center"
							wrap="Wrap">

							<VBox id="_IDGenVBox10" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel10" text="Tipo de Ocorrência" />
								<Input id="_IDGenInput2"
									width="9rem"
									value="{mdlOcorrenciasFiltradas>TipoOcorrencia}"
									editable="{mdlOcorrenciasFiltradas>editModeTipoOcorrencia}"
									showValueHelp="true"
									valueHelpOnly="true"
									valueHelpRequest=".onValueHelpRequestTipoOcorrencia" />
							</VBox>

							<VBox id="_IDGenVBox11" class="sapUiSmallMarginEnd">
								<Label id="_IDGenLabel11" text="Justificativa" />
								<Input id="_IDGenInput3"
									width="18rem"
									value="{mdlOcorrenciasFiltradas>JustificativaTexto}"
									showValueHelp="true"
									valueHelpOnly="true"
									valueHelpRequest=".onValueHelpRequestCodigoFrequencia"
									editable="{mdlOcorrenciasFiltradas>editMode}" />
							</VBox>

						</HBox>

						<!-- Linha 4: observação -->
						<VBox id="_IDGenVBox12" class="sapUiSmallMarginTop">
							<Label id="_IDGenLabel12" text="Observação" />
							<Input id="_IDGenInput4"
								value="{mdlOcorrenciasFiltradas>Observacao}"
								editable="{mdlOcorrenciasFiltradas>editMode}"
								maxLength="72"
								width="100%" />
						</VBox>

						<!-- Linha 5: ações da linha -->
						<OverflowToolbar id="_IDGenOverflowToolbar"
							class="sapUiTinyMarginTop"
							design="Transparent">

							<ToolbarSpacer id="_IDGenToolbarSpacer" />

							<Button id="_IDGenButton7"
								icon="sap-icon://save"
								type="Transparent"
								tooltip="Salvar"
								press=".onSalvarLinha" />

							<Button id="_IDGenButton8"
								icon="sap-icon://delete"
								type="Transparent"
								tooltip="Cancelar"
								press=".onCancelarLinha" />

							<Button id="_IDGenButton9"
								icon="sap-icon://attachment"
								type="Transparent"
								tooltip="Anexar"
								press=".onAbrirFragmentTelaAnexo" />

						</OverflowToolbar>

					</VBox>

				</CustomListItem>

			</List>
   

		</f:content>

		<!-- DynamicPage Footer -->
		<f:footer>
			<OverflowToolbar id="_IDGenOverflowToolbar1">
				<ToolbarSpacer id="_IDGenToolbarSpacer1"/>
				<Button id="_IDGenButton" type="Accept" text="Accept"/>
				<Button id="_IDGenButton1" type="Reject" text="Reject"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>