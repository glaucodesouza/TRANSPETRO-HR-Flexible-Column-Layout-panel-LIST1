<mvc:View controllerName="zhr.flexiblecolumnlayoutlist.controller.List"
    displayBlock="true"
    width="100%"  
    height="100%"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core">
	<f:DynamicPage id="dynamicPageId"
				   toggleHeaderOnTitleClick="false">
		<!-- DynamicPage Title -->
		<f:title>
			<f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
				<f:heading>
					<Title id="_IDGenTitle" text="Products"/>
				</f:heading>
			</f:DynamicPageTitle>
		</f:title>


        <!-- Header com seleção de período -->
        <f:header>
            <f:DynamicPageHeader id="dynamicPageHeader">
                <f:content>

                    <HBox
                        id="boxFiltrosPeriodo"
                        alignItems="Center"
                        class="sapUiSmallMargin">

                        <Label
                            id="lblPeriodo"
                            text="Período:"
                            labelFor="cmbPeriodos"
                            class="sapUiTinyMarginEnd"/>

                        <Select
                            id="cmbPeriodos"
                            width="300px"
                            change=".onComboBoxPeriodosChange"
                            items="{mdlPeriodos>/}">
                            <core:Item id="_IDGenItem"
                                key="{mdlPeriodos>Periodo}"
                                text="{mdlPeriodos>PeriodoTexto}"/>
                        </Select>

                    </HBox>

                </f:content>
            </f:DynamicPageHeader>
        </f:header>


		<!-- DynamicPage Content -->
		<f:content>

			<List id="_IDGenList1"
				growing="true"
				growingThreshold="10"
				growingDirection="Upwards"
				busyIndicatorDelay="200"
				enableBusyIndicator="true"
				growingTriggerText="Previous Products"
				noDataText="No products available"
				items="{
					path: 'mdlOcorrenciasFiltradas>/',
					sorter: {
						path: 'UnidadeOrganizacional',
						descending: false,
						group: '.listGroupFunction'
					}
				}">
				<StandardListItem id="_IDGenStandardListItem"
					title="{mdlOcorrenciasFiltradas>Empregado}"
					description="{mdlOcorrenciasFiltradas>NomeEmpregado}"
					info="{mdlOcorrenciasFiltradas>HoraInicio} {mdlOcorrenciasFiltradas>HoraFim}" />
			</List>        

		</f:content>

		<!-- DynamicPage Footer -->
		<f:footer>
			<OverflowToolbar id="_IDGenOverflowToolbar1">
				<ToolbarSpacer id="_IDGenToolbarSpacer1"/>
				<Button id="_IDGenButton" type="Accept" text="Accept"/>
				<Button id="_IDGenButton1" type="Reject" text="Reject"/>
			</OverflowToolbar>
		</f:footer>
	</f:DynamicPage>
</mvc:View>